    "load:test": "tsx scripts/load-test.ts"
  },
  "dependencies": {
    "@queue-monitor/node": "1.0.0",
    "@queue-monitor/shared": "1.0.0",
    "bullmq": "^5.58.0",
    "express": "^5.1.0",
    "pg": "^8.16.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.4",
    "light-my-request": "^6.6.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
