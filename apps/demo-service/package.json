{
  "name": "@queue-monitor/demo-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
