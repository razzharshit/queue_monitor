# Copy to infra/.env and replace every placeholder. infra/.env is gitignored.
POSTGRES_DB=queue_monitor
POSTGRES_USER=queue_monitor
POSTGRES_PASSWORD=replace-with-a-random-database-password
DATABASE_URL=postgres://queue_monitor:replace-with-a-random-database-password@postgres:5432/queue_monitor

JWT_SECRET=replace-with-at-least-32-random-characters
COOKIE_SECURE=false
HTTPS_ENFORCE=false
TRUST_PROXY=true
WEB_ORIGIN=http://localhost:4173
APP_URL=http://localhost:4173

# Optional invitation and password-reset email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
MAX_REQUEST_BYTES=1048576
MAX_EVENT_BYTES=16384
MAX_BATCH_SIZE=100
MAX_NESTING_DEPTH=12

DEMO_LOGIN_EMAIL=replace-with-a-demo-email
DEMO_LOGIN_PASSWORD=replace-with-at-least-12-characters
DEMO_LOGIN_NAME="Demo Operator"
DEMO_ORGANIZATION_NAME="Demo Organization"
DEMO_ORGANIZATION_SLUG=demo-organization
DEMO_PROJECT_NAME="Demo Project"
DEMO_PROJECT_SLUG=demo-project
DEMO_ENVIRONMENT_NAME=Development
DEMO_ENVIRONMENT_SLUG=development
DEMO_ENVIRONMENT_TYPE=development
DEMO_API_KEY=qmon_live_replace_with_a_random_value
# Optional dedicated read-only workspace generator key (local demo command writes this to .env).
DEMO_VIEWER_EMAIL=
DEMO_VIEWER_PASSWORD=
DEMO_SEED_API_KEY=
DEMO_ENVIRONMENT_ID=

LOG_LEVEL=info
APP_VERSION=0.1.0
GIT_COMMIT_SHA=unknown
BUILD_TIMESTAMP=2026-01-01T00:00:00.000Z
