# Copy to .env and replace all blank/placeholder values. .env is gitignored.
DATABASE_URL=
PORT=3000
APP_HOST=0.0.0.0
LOG_LEVEL=info
JWT_SECRET=
NODE_ENV=development
COOKIE_SECURE=false
HTTPS_ENFORCE=false
TRUST_PROXY=false
WEB_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
TELEMETRY_DATA_ALLOWLIST=

# Optional SMTP invitation and password-reset delivery. If omitted, email delivery is disabled.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Ingestion abuse protection
MAX_REQUEST_BYTES=1048576
MAX_EVENT_BYTES=16384
MAX_BATCH_SIZE=100
MAX_NESTING_DEPTH=12

# Demo seed and SDK
DEMO_LOGIN_EMAIL=
DEMO_LOGIN_PASSWORD=
DEMO_LOGIN_NAME="Demo Operator"
DEMO_ORGANIZATION_NAME="Demo Organization"
DEMO_ORGANIZATION_SLUG=demo-organization
DEMO_PROJECT_NAME="Demo Project"
DEMO_PROJECT_SLUG=demo-project
DEMO_ENVIRONMENT_NAME=Development
DEMO_ENVIRONMENT_SLUG=development
DEMO_ENVIRONMENT_TYPE=development
DEMO_API_KEY=
QMON_API_KEY=
# Created locally by npm run demo:seed-account. Never commit either value.
DEMO_VIEWER_EMAIL=
DEMO_VIEWER_PASSWORD=
DEMO_SEED_API_KEY=
DEMO_ENVIRONMENT_ID=
INGESTION_ENDPOINT=http://localhost:3000
REDIS_URL=redis://localhost:6379
DEMO_PORT=3001
DEMO_HOST=0.0.0.0
DEMO_ENVIRONMENT=development

# Optional release metadata
APP_VERSION=0.1.0
GIT_COMMIT_SHA=unknown
BUILD_TIMESTAMP=2026-01-01T00:00:00.000Z

# Web build-time values (never put secrets in VITE_* variables)
VITE_API_URL=
VITE_APP_ENV=development
VITE_LOG_LEVEL=info
